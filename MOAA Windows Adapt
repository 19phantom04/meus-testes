# 2. Lógica de "Annoyance" (Irritação) - Rato e Teclado
Add-Type -AssemblyName System.Windows.Forms
$wsh = New-Object -ComObject WScript.Shell

# Loop de 10 ciclos para não travar o PC infinitamente durante o teste
for ($i = 0; $i -lt 10; $i++) {
    # Mover Rato aleatoriamente
    [System.Windows.Forms.Cursor]::Position = New-Object System.Drawing.Point((Get-Random -Min 0 -Max 1000), (Get-Random -Min 0 -Max 1000))
    
    # Alternar Wi-Fi (Desliga e Liga a primeira interface encontrada)
    Get-NetAdapter | Disable-NetAdapter -Confirm:$false
    Start-Sleep -Seconds 2
    Get-NetAdapter | Enable-NetAdapter -Confirm:$false
    
    # Alternar CAPSLOCK
    $wsh.SendKeys('{CAPSLOCK}')
    Start-Sleep -Seconds 2
}

exit
